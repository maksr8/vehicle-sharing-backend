        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();",
                  "let token = response.data.accessToken || (response.data && response.data.token);",
                  "if (token) {",
                  "    pm.collectionVariables.set(\"token\", token);",
                  "    console.log(\"Token extracted and set automatically.\");",
                  "}"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"email\": \"test@example.com\",\n    \"password\": \"securepassword123\"\n}",
