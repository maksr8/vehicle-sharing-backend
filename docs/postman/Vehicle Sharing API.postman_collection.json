    {
      "name": "2. User Actions",
      "item": [
        {
          "name": "Get Available Vehicles",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();",
                  "let vehicles = response.data || response;",
                  "// Find the first actually available vehicle to use for the next ride test",
                  "let availableVehicle = vehicles.find(v => v.available === true && v.isActive === true);",
                  "if (availableVehicle) {",
                  "    pm.collectionVariables.set(\"vehicleId\", availableVehicle.id);",
                  "    console.log(\"Saved available vehicleId for next request.\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/vehicles?page=1&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "vehicles"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Start Ride",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "let response = pm.response.json();",
                  "let ride = response.data || response;",
                  "if (ride && ride.id) {",
                  "    pm.collectionVariables.set(\"rideId\", ride.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"vehicleId\": \"{{vehicleId}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/rides",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "rides"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get My Rides",
          "request": {
            "method": "GET",
