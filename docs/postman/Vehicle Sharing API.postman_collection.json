    {
      "name": "4. GraphQL",
      "item": [
        {
          "name": "Query: Get Vehicles",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "query GetVehicles($page: Int, $limit: Int) {\n  vehicles(page: $page, limit: $limit) {\n    data {\n      id\n      model\n      licensePlate\n      available\n      isActive\n      pricePerMinuteCents\n    }\n    meta {\n      total\n      totalPages\n      page\n    }\n  }\n}",
                "variables": "{\n  \"page\": 1,\n  \"limit\": 10\n}"
              }
            },
            "url": {
              "raw": "http://localhost:8080/graphql",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "graphql"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Mutation: Start Ride",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation StartRide($vehicleId: ID!) {\n  startRide(vehicleId: $vehicleId) {\n    id\n    status\n    rideDate\n    vehicle {\n      model\n    }\n  }\n}",
                "variables": "{\n  \"vehicleId\": \"{{vehicleId}}\"\n}"
              }
            },
            "url": {
              "raw": "http://localhost:8080/graphql",
              "protocol": "http",
              "host": [
                "localhost"
              ],
